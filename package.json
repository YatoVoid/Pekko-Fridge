{
  "name": "pekko-fridge",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start --go",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "node tests/dateParser.test.js && node tests/expiry.test.js",
    "test:tz": "cross-env TZ=America/New_York node tests/expiry.test.js && cross-env TZ=Asia/Tokyo node tests/expiry.test.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "^56.0.12",
    "expo-camera": "~56.0.8",
    "expo-dev-client": "^56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-notifications": "^56.0.18",
    "expo-sensors": "~56.0.6",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition"
        ]
      }
    }
  },
  "devDependencies": {
    "babel-preset-expo": "^56.0.15",
    "cross-env": "^10.1.0"
  }
}
