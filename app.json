{
  "expo": {
    "name": "Pekko Fridge",
    "slug": "pekko-fridge",
    "version": "1.1.2",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pekko.fridge",
      "infoPlist": {
        "NSCameraUsageDescription": "Pekko uses the camera to scan expiry dates. Photos never leave your phone."
      }
    },
    "android": {
      "package": "com.pekko.fridge",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF6EE"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Pekko uses the camera to scan expiry dates locally."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pekko lets you attach photos of your food. They stay on your phone."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "076b5975-8a35-48be-a951-dcbbd32b2be7"
      }
    }
  }
}
